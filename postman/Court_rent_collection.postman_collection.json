              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Convertir la respuesta a un objeto JSON\r",
                  "const response = pm.response.json();\r",
                  "\r",
                  "// 2. Extraer el token (ajusta 'access_token' si tu API usa otro nombre)\r",
                  "const token = response.access_token;\r",
                  "\r",
                  "// 3. Guardarlo en una variable de entorno o de colección\r",
                  "if (token) {\r",
                  "    pm.globals.set(\"mi_token_auth\", token);\r",
                  "    console.log(\"Token guardado con éxito\");\r",
                  "} else {\r",
                  "    console.error(\"No se encontró el token en la respuesta\");\r",
                  "}"
